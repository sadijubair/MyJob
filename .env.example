# MyJob environment template
# Copy this file to .env.local and fill in your values.

DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require
PAYLOAD_SECRET=your-payload-secret-here
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
REVALIDATE_SECRET=your-revalidate-secret-here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here